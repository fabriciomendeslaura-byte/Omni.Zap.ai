  {
    "parameters": {
      "jsCode": "// Pega o body do webhook\nconst body = $json.body;\n\n// 1️⃣ Bloqueia apenas mensagens enviadas pelo próprio agente\nif (body.fromMe === true) {\n  return [];\n}\n\n// 2️⃣ Identifica tipo da mensagem\nlet mensagemLead = null;\nlet tipoMensagem = null;\n\nif (body.text && body.text.message) {\n  tipoMensagem = \"texto\";\n  mensagemLead = body.text.message;\n} \nelse if (body.audio) {\n  tipoMensagem = \"audio\";\n  mensagemLead = body.audio;\n}\nelse if (body.image) {\n  tipoMensagem = \"imagem\";\n  mensagemLead = body.image;\n}\nelse if (body.document) {\n  tipoMensagem = \"documento\";\n  mensagemLead = body.document;\n}\nelse {\n  // Se não for nenhum desses, ainda deixa passar\n  tipoMensagem = \"outro\";\n  mensagemLead = body;\n}\n\n// 3️⃣ Retorna mantendo sua estrutura original\nreturn [\n  {\n    json: {\n      ...$json,\n      tipoMensagem,\n      mensagemLead,\n      telefoneLead: body.phone,\n      messageId: body.messageId\n    }\n  }\n];"
    },
    "type": "n8n-nodes-base.code",
    "typeVersion": 2,
    "position": [
      -1872,
      784
    ],
