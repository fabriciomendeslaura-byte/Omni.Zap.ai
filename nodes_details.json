  {
    "parameters": {
      "jsCode": "const resultado = [];\n\nfor (const item of items) {\n  \n  const followUp = item.json.follow_up;\n  const ultimaMensagem = item.json.ultima_mensagem;\n\n  if (!ultimaMensagem) {\n    continue; // evita erro se vier null\n  }\n\n  const agora = new Date();\n  const ultima = new Date(ultimaMensagem);\n\n  const diferencaHoras = (agora - ultima) / (1000 * 60 * 60);\n\n  if (followUp === \"follow_up2\" && diferencaHoras >= 24) {\n    resultado.push(item);\n  }\n}\n\nreturn resultado;"
    },
    "type": "n8n-nodes-base.code",
    "typeVersion": 2,
    "position": [
      -272,
      3264
    ],
    "id": "421f62db-7370-4579-9f45-1390f72fcb4f",
    "name": "Code in JavaScript1"
  },
  {
    "parameters": {
      "jsCode": "const agora = new Date();\n\n// Ajusta pro fuso do Brasil (importante se teu n8n estiver em servidor gringo)\nconst horaBrasil = new Date(\n  agora.toLocaleString(\"en-US\", { timeZone: \"America/Sao_Paulo\" })\n).getHours();\n\n// Define o horário comercial\nconst inicio = 8;  // 08:00\nconst fim = 19;    // 19:00\n\n// Verifica se está dentro do horário\nconst dentroHorario = horaBrasil >= inicio && horaBrasil < fim;\n\n// Se estiver dentro do horário, deixa passar\nif (dentroHorario) {\n  return items.map(item => {\n    return {\n      json: {\n        ...item.json,\n        dentroHorario: true,\n        horaAtual: horaBrasil\n      }\n    };\n  });\n}\n\n// Se NÃO estiver, bloqueia o fluxo\nreturn [];"
    },
    "type": "n8n-nodes-base.code",
    "typeVersion": 2,
    "position": [
      -1728,
      2640
    ],
